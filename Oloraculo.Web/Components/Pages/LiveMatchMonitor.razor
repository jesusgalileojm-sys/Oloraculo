@page "/live/{MatchId}"
@using Oloraculo.Web.Services
@using Oloraculo.Web.Models
@inject ILiveMatchService LiveService
@inject NavigationManager Nav
@inject ILogger<LiveMatchMonitor> Logger

<div class="live-match-container">
    <div class="match-header">
        @if (CurrentMatch != null)
        {
            <div class="score-display">
                <div class="team home">
                    <h2>@CurrentMatch.HomeTeam.Name</h2>
                    <div class="score">@CurrentMatch.HomeScore</div>
                </div>
                
                <div class="match-info">
                    <span class="status">@GetStatusText(CurrentMatch.Status)</span>
                    <span class="minute">@CurrentMatch.Minute'</span>
                </div>
                
                <div class="team away">
                    <h2>@CurrentMatch.AwayTeam.Name</h2>
                    <div class="score">@CurrentMatch.AwayScore</div>
                </div>
            </div>
        }
    </div>

    @if (GoalProbability != null)
    {
        <div class="predictions-card">
            <h3>⚡ Probabilidad de Gol Actualizada</h3>
            
            <div class="probability-grid">
                <div class="prob-item">
                    <label>Próximos 5 min</label>
                    <div class="prob-bar">
                        <div class="prob-fill" style="width: @(GoalProbability.Next5Minutes * 100)%"></div>
                    </div>
                    <span class="prob-value">@(GoalProbability.Next5Minutes * 100:F1)%</span>
                </div>
                
                <div class="prob-item">
                    <label>Próximos 15 min</label>
                    <div class="prob-bar">
                        <div class="prob-fill" style="width: @(GoalProbability.Next15Minutes * 100)%"></div>
                    </div>
                    <span class="prob-value">@(GoalProbability.Next15Minutes * 100:F1)%</span>
                </div>
                
                <div class="prob-item">
                    <label>Hasta el final</label>
                    <div class="prob-bar">
                        <div class="prob-fill" style="width: @(GoalProbability.EndOfMatch * 100)%"></div>
                    </div>
                    <span class="prob-value">@(GoalProbability.EndOfMatch * 100:F1)%</span>
                </div>
            </div>
        </div>

        <div class="reasoning-card">
            <h4>📊 Análisis Detallado</h4>
            <div class="reasoning-text">
                @((MarkupString)GoalProbability.Reasoning)
            </div>
            <p class="updated-at">
                Actualizado: @GoalProbability.UpdatedAt.ToString("HH:mm:ss")
            </p>
        </div>
    }

    @if (CurrentMatch?.Statistics != null)
    {
        <div class="stats-grid">
            <div class="stat-card">
                <h5>Estadísticas</h5>
                <table>
                    <tr>
                        <td>Posesión</td>
                        <td>@(CurrentMatch.Statistics.HomeTeam.Possession)%</td>
                        <td>@(CurrentMatch.Statistics.AwayTeam.Possession)%</td>
                    </tr>
                    <tr>
                        <td>Tiros</td>
                        <td>@CurrentMatch.Statistics.HomeTeam.TotalShots</td>
                        <td>@CurrentMatch.Statistics.AwayTeam.TotalShots</td>
                    </tr>
                    <tr>
                        <td>Tiros al arco</td>
                        <td>@CurrentMatch.Statistics.HomeTeam.ShotsOnTarget</td>
                        <td>@CurrentMatch.Statistics.AwayTeam.ShotsOnTarget</td>
                    </tr>
                    <tr>
                        <td>Córners</td>
                        <td>@CurrentMatch.Statistics.HomeTeam.Corners</td>
                        <td>@CurrentMatch.Statistics.AwayTeam.Corners</td>
                    </tr>
                    <tr>
                        <td>xG</td>
                        <td>@CurrentMatch.Statistics.HomeTeam.ExpectedGoals.ToString("F2")</td>
                        <td>@CurrentMatch.Statistics.AwayTeam.ExpectedGoals.ToString("F2")</td>
                    </tr>
                </table>
            </div>
        </div>
    }

    <div class="controls">
        <button class="btn btn-primary" @onclick="RefreshData">
            🔄 Actualizar ahora
        </button>
        <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo('/matches')">
            ← Volver a partidos
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="loading">
            <p>⏳ Cargando datos en vivo...</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="error-message">
            <p>⚠️ @ErrorMessage</p>
        </div>
    }
</div>

<style>
.live-match-container {
    padding: 20px;
    max-width: 900px;
    margin: 0 auto;
}

.match-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px;
    border-radius: 12px;
    margin-bottom: 30px;
}

.score-display {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 40px;
    align-items: center;
    text-align: center;
}

.team h2 {
    margin: 0 0 10px 0;
    font-size: 18px;
}

.score {
    font-size: 48px;
    font-weight: bold;
}

.match-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.status {
    font-size: 14px;
    opacity: 0.9;
}

.minute {
    font-size: 24px;
    font-weight: bold;
}

.predictions-card {
    background: white;
    border: 2px solid #667eea;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 20px;
}

.probability-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.prob-item {
    padding: 15px;
    background: #f8f9fa;
    border-radius: 8px;
}

.prob-item label {
    display: block;
    font-weight: bold;
    margin-bottom: 10px;
    color: #333;
}

.prob-bar {
    width: 100%;
    height: 30px;
    background: #e9ecef;
    border-radius: 15px;
    overflow: hidden;
    margin-bottom: 10px;
}

.prob-fill {
    height: 100%;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    transition: width 0.3s ease;
}

.prob-value {
    font-size: 18px;
    font-weight: bold;
    color: #667eea;
}

.reasoning-card {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 20px;
    border-left: 4px solid #667eea;
}

.reasoning-text {
    margin-top: 15px;
    line-height: 1.6;
    color: #333;
    font-size: 14px;
}

.reasoning-text strong {
    color: #667eea;
}

.updated-at {
    margin-top: 15px;
    font-size: 12px;
    color: #999;
    text-align: right;
}

.stats-grid {
    background: white;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 20px;
}

.stat-card table {
    width: 100%;
    border-collapse: collapse;
}

.stat-card table tr {
    border-bottom: 1px solid #eee;
}

.stat-card table td {
    padding: 12px;
    text-align: center;
}

.stat-card table td:first-child {
    text-align: left;
    font-weight: bold;
    color: #667eea;
}

.controls {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 30px;
}

.btn {
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-primary {
    background: #667eea;
    color: white;
}

.btn-primary:hover {
    background: #764ba2;
    transform: scale(1.05);
}

.btn-secondary {
    background: #e9ecef;
    color: #333;
}

.btn-secondary:hover {
    background: #dee2e6;
}

.loading, .error-message {
    text-align: center;
    padding: 20px;
    border-radius: 8px;
    margin-top: 20px;
}

.loading {
    background: #e3f2fd;
    color: #1976d2;
}

.error-message {
    background: #ffebee;
    color: #c62828;
}
</style>

@code {
    [Parameter]
    public string MatchId { get; set; }

    private SofascoreLiveMatch CurrentMatch { get; set; }
    private GoalProbabilityUpdate GoalProbability { get; set; }
    private bool IsLoading = false;
    private string ErrorMessage = "";
    private PeriodicTimer _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        
        // Actualizar cada 30 segundos
        _refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        _ = AutoRefresh();
    }

    private async Task LoadData()
    {
        if (!int.TryParse(MatchId, out int matchIdInt))
        {
            ErrorMessage = "ID de partido inválido";
            return;
        }

        try
        {
            IsLoading = true;
            ErrorMessage = "";

            // Obtener contexto en vivo
            var context = await LiveService.GetLiveContextAsync(
                matchIdInt,
                baseGoalProbability: 0.3 // Esto debería venir de tu predicción pre-partido
            );

            CurrentMatch = context.LiveMatch;
            GoalProbability = await LiveService.CalculateLiveGoalProbabilityAsync(context);

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error cargando datos: {ex.Message}");
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    private async Task AutoRefresh()
    {
        try
        {
            while (await _refreshTimer.WaitForNextTickAsync())
            {
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError($"Error en auto-refresh: {ex.Message}");
        }
    }

    private string GetStatusText(string status) => status switch
    {
        "inProgress" => "🔴 EN VIVO",
        "finished" => "✅ FINALIZADO",
        "notStarted" => "⏳ NO COMENZÓ",
        _ => "❓ DESCONOCIDO"
    };

    public async ValueTask DisposeAsync()
    {
        if (_refreshTimer != null)
        {
            await _refreshTimer.DisposeAsync();
        }
    }
}
