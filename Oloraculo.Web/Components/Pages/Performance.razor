@page "/performance"
@rendermode InteractiveServer
@inject EvaluationService Evaluation
@inject OloraculoDbContext Db

<PageTitle>Performance</PageTitle>

<div class="page-head">
    <h1>Performance</h1>
    <p>Saved predictions scored with Brier, ranked probability score, log loss, and top-pick accuracy.</p>
</div>

@if (_performance.Count == 0)
{
    <div class="banner warn">No evaluations yet.</div>
}
else
{
    <div class="card">
        <h2>Model Scores</h2>
        <table>
            <thead><tr><th>Model</th><th class="num">N</th><th class="num">Top pick</th><th class="num">RPS</th><th class="num">Brier</th><th class="num">Log loss</th></tr></thead>
            <tbody>
                @foreach (var row in _performance)
                {
                    <tr>
                        <td>@row.ModelName</td>
                        <td class="num">@row.Count</td>
                        <td class="num">@row.TopPickAccuracy.ToString("P0")</td>
                        <td class="num">@row.MeanRps.ToString("0.000")</td>
                        <td class="num">@row.MeanBrier.ToString("0.000")</td>
                        <td class="num">@row.MeanLogLoss.ToString("0.000")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="grid cols-2">
        <div class="card">
            <h2>Best Calls</h2>
            <table>
                <thead><tr><th>Match</th><th class="num">RPS</th></tr></thead>
                <tbody>
                    @foreach (var e in _best)
                    {
                        <tr><td>@Name(e.HomeTeamId) @e.HomeGoals-@e.AwayGoals @Name(e.AwayTeamId)</td><td class="num">@e.RankedProbabilityScore.ToString("0.000")</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card">
            <h2>Overconfident Misses</h2>
            <table>
                <thead><tr><th>Match</th><th class="num">Log loss</th></tr></thead>
                <tbody>
                    @foreach (var e in _worst)
                    {
                        <tr><td>@Name(e.HomeTeamId) @e.HomeGoals-@e.AwayGoals @Name(e.AwayTeamId)</td><td class="num">@e.LogLoss.ToString("0.000")</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private IReadOnlyList<ModelPerformanceRow> _performance = [];
    private IReadOnlyList<PredictionEvaluation> _best = [];
    private IReadOnlyList<PredictionEvaluation> _worst = [];
    private Dictionary<string, string> _names = [];

    protected override async Task OnInitializedAsync()
    {
        _names = await Db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);
        _performance = await Evaluation.PerformanceAsync();
        _best = await Evaluation.BestCallsAsync();
        _worst = await Evaluation.OverconfidentFailuresAsync();
    }

    private string Name(string id) => _names.TryGetValue(id, out var name) ? name : id;
}
